# =============================================================================
# AI-aware additions (managed by claude-starter)
# =============================================================================

# Claude private workspace — sensitive scratch, untriaged data.
# Claude can read it; git never sees it.
.ai_context/private/

# Local-only Claude context — per-machine notes that should not be shared.
# e.g., state.local.md or knowledge/api-spec.local.md
.ai_context/**/*.local.md

# Claude session caches (if any tool drops these)
.claude/cache/

# Stop-gate PASS-cache — runtime state; MUST stay ignored (gitignoring it
# keeps it out of its own change-fingerprint).
.ai_context/tasks/*/.gate-cache

# Local-only Claude Code settings (machine-specific permissions etc.)
# .claude/settings.json IS tracked on purpose — it carries shared hooks.
.claude/settings.local.json

# =============================================================================
# Standard ignores (append your language/framework's ignores below)
# =============================================================================

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp
*.swo

# Env / secrets — any depth, not just repo root
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# Append your language-specific ignores (node_modules/, __pycache__/, target/,
# build/, dist/, etc.) here, or use `gh repo create --gitignore <lang>` to
# generate one.
