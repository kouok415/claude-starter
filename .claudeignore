# What Claude should not waste tokens reading.
# Different from .gitignore: lock files belong here (Claude doesn't learn from
# them), but they DO belong in git for reproducibility.

# === Build & dependency artifacts ===
node_modules/
.venv/
venv/
__pycache__/
*.pyc
*.pyo
target/
build/
dist/
out/
.next/
.nuxt/
.svelte-kit/
.turbo/
.cache/
coverage/
.nyc_output/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/

# === Lock files (large, no semantic value for Claude) ===
package-lock.json
yarn.lock
pnpm-lock.yaml
poetry.lock
Cargo.lock
composer.lock
Gemfile.lock
uv.lock

# === Generated code (read source, not output) ===
*.generated.*
*.gen.go
*.pb.go
*_pb2.py
*_pb2_grpc.py
schema.graphql.d.ts
*.d.ts.map

# === Binary / media (token-expensive, low signal) ===
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.svg
*.mp4
*.mov
*.webm
*.zip
*.tar
*.tar.gz
*.gz
*.7z
*.pdf
*.docx
*.xlsx
*.pptx

# === Logs ===
*.log
logs/

# === IDE & system ===
.idea/
.vscode/
.DS_Store

# Note: .ai_context/ is intentionally NOT ignored. Claude needs to read it.
